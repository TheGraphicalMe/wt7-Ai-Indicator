# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8000
NODE_ENV=development

# Anthropic API — get your key from https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS — comma-separated list of frontend URLs allowed to call this API
# In development you can use: http://localhost:3000
# In production use your actual domain: https://tradingschoolbywizardtrader.com
ALLOWED_ORIGINS=http://localhost:3000,https://tradingschoolbywizardtrader.com

# Rate limiting
# RATE_LIMIT_WINDOW_MS   — time window in milliseconds (900000 = 15 minutes)
# RATE_LIMIT_MAX_REQUESTS — max requests allowed per IP in that window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=30

# Slow-down (kicks in before hard block)
# SLOW_DOWN_DELAY_AFTER — requests before slowdown starts
# SLOW_DOWN_DELAY_MS    — extra milliseconds added per request after the limit
SLOW_DOWN_DELAY_AFTER=10
SLOW_DOWN_DELAY_MS=500

# Claude token budget — max tokens Claude can output per single response
# 1024 is a good balance of detail and cost control
MAX_TOKENS_PER_RESPONSE=1024

# Input validation
# MAX_MESSAGE_LENGTH   — max characters in a single user message
# MAX_HISTORY_MESSAGES — max number of past exchanges to include
MAX_MESSAGE_LENGTH=1000
MAX_HISTORY_MESSAGES=10
